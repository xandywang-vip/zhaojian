# 「易见」后端环境变量样例。复制为 .env 后填入真实值。
# 不要把 .env 提交到 git。

# === 基础 ===
APP_BASE_URL=http://localhost:3000
PORT=3001
DATABASE_URL=

# === 大模型（任选一家，默认 DeepSeek） ===
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Prompt 可调旋钮（见 易见-AI解卦Prompt.md 第 7 节）
LLM_TONE=温和平实，像一位有阅历的顾问
LLM_DEPTH=详细，引用爻辞原文逐层解释，建议条目用第一第二第三列出
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1800
LLM_TIMEOUT_MS=20000

# === 微信公众号（M4 阶段使用） ===
WX_APPID=
WX_APPSECRET=

# === 微信支付（M4 阶段使用） ===
WX_MCH_ID=
WX_PAY_API_V3_KEY=
WX_PAY_CERT_SERIAL=
WX_PAY_PRIVATE_KEY_PATH=
WX_PAY_NOTIFY_URL=

# === 短信服务（M4 阶段使用） ===
SMS_ACCESS_KEY=
SMS_SECRET=
